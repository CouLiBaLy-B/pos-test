# Ports
VLLM_PORT=8000
ASSISTANT_API_PORT=8080

# vLLM model configuration
VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct-AWQ
VLLM_SERVED_MODEL_NAME=claude-sonnet-local
VLLM_TOOL_CALL_PARSER=qwen3_xml
VLLM_MAX_MODEL_LEN=65536
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_DTYPE=float16

# Docker / cache paths
HF_HOME=${HOME}/.cache/huggingface

# Claude Code env expected locally (direct vLLM, no LiteLLM)
ANTHROPIC_BASE_URL=http://localhost:8000
ANTHROPIC_AUTH_TOKEN=dummy
ANTHROPIC_API_KEY=dummy
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-local
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-sonnet-local
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-sonnet-local
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
ENABLE_TOOL_SEARCH=false

# Assistant API
ASSISTANT_UPSTREAM_BASE_URL=http://localhost:8000
ASSISTANT_AUTH_TOKEN=dummy
ASSISTANT_API_KEY=dummy
ASSISTANT_MODEL=claude-sonnet-local
ASSISTANT_DEFAULT_MAX_TOKENS=2048
ASSISTANT_REQUEST_TIMEOUT=120
ASSISTANT_SYSTEM_PROMPT=
ASSISTANT_ANTHROPIC_VERSION=2023-06-01
