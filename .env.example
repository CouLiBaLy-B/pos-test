# Ports
VLLM_PORT=8000
LITELLM_PORT=4000
ASSISTANT_API_PORT=8080

# vLLM model configuration
VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct-AWQ
VLLM_SERVED_MODEL_NAME=qwen3-coder
VLLM_TOOL_CALL_PARSER=qwen3_xml
VLLM_MAX_MODEL_LEN=65536
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_DTYPE=float16

# Docker / cache paths
HF_HOME=${HOME}/.cache/huggingface

# LiteLLM
LITELLM_MASTER_KEY=sk-local-admin-change-me

# Claude Code env expected locally
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_AUTH_TOKEN=sk-local-dummy
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ENABLE_TOOL_SEARCH=true

# Assistant API
ASSISTANT_UPSTREAM_BASE_URL=http://localhost:4000
ASSISTANT_AUTH_TOKEN=sk-local-dummy
ASSISTANT_MODEL=claude-3-5-sonnet-20241022
ASSISTANT_DEFAULT_MAX_TOKENS=2048
ASSISTANT_REQUEST_TIMEOUT=120
ASSISTANT_SYSTEM_PROMPT=
