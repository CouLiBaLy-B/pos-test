{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8000",
    "ANTHROPIC_AUTH_TOKEN": "dummy",
    "ANTHROPIC_API_KEY": "dummy",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-local",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-local",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-sonnet-local",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1",
    "ENABLE_TOOL_SEARCH": "false"
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",
      "Bash(./scripts/sandbox-up.sh:*)",
      "Bash(./scripts/sandbox-down.sh:*)",
      "Bash(./scripts/sandbox-shell.sh:*)",
      "Bash(./scripts/sandbox-run.sh:*)",
      "Bash(./scripts/sandbox-test.sh:*)",
      "Bash(./scripts/claude-sandbox.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(make:*)",
      "Bash(git:*)"
    ]
  }
}
